# Puerto del dashboard (por defecto 3000)
PORT=3000

# Token del bot de Telegram — obtén el tuyo en https://t.me/BotFather
TELEGRAM_TOKEN=123456789:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TELEGRAM_BOT_USERNAME=tu_bot_username

# ID del chat donde el bot enviará notificaciones de nuevos leads
TELEGRAM_CHAT_ID=tu_chat_id

# IDs de los administradores (separados por coma) — pueden usar /leads y /confirmar
TELEGRAM_ADMIN_IDS=123456789,987654321

# Credenciales del admin inicial (obligatorio en el primer arranque)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=pon-aqui-una-contrasena-segura

# Clave de cifrado AES-256-GCM para datos sensibles (DNI, teléfono, notas clínicas)
# OBLIGATORIO — generar con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=pon-aqui-64-caracteres-hex-generados-con-el-comando-de-arriba

# Poner a 1 SOLO si el servidor está detrás de un reverse proxy de confianza (nginx, Caddy, etc.)
# que inyecte la cabecera X-Forwarded-For. En acceso directo a internet dejar vacío.
TRUST_PROXY=

# (Opcional) API key de Google Gemini para respuestas con IA
# Sin esta variable el bot funciona con respuestas predefinidas locales
# Obtén la tuya gratis en https://aistudio.google.com/apikey
GEMINI_API_KEY=
